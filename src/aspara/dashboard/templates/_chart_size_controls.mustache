<span class="text-sm text-text-secondary">Chart size:</span>
<div class="flex border border-base-border rounded overflow-hidden">
  <button id="sizeS" title="Small charts (~300px wide, more charts per row)" class="px-3 py-1 text-sm bg-base-surface text-text-primary hover:bg-base-bg transition-colors">Small</button>
  <button id="sizeM" title="Medium charts (~400px wide, balanced — default)" class="px-3 py-1 text-sm bg-action text-white hover:bg-action-hover transition-colors">Medium</button>
  <button id="sizeL" title="Large charts (~600px wide, fewer charts per row)" class="px-3 py-1 text-sm bg-base-surface text-text-primary hover:bg-base-bg transition-colors">Large</button>
</div>
